# Base de datos (local)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/saas_ecommerce

# Redis
REDIS_URL=redis://localhost:6379

# Autenticación (cambiar por un valor generado)
AUTH_SECRET=cambia_esto_por_un_secreto_aleatorio

# MinIO (cambiar por tus access keys)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tu_access_key
MINIO_SECRET_KEY=tu_secret_key
MINIO_BUCKET=saas-media
MINIO_USE_SSL=false

# Email (MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@saas.local

# MercadoPago
# Obtén tus credenciales en https://www.mercadopago.com/developers/panel
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx
# true for sandbox (test mode), false for production
MP_USE_SANDBOX=true

# Public URL for MercadoPago back_urls (e.g., ngrok, cloudflare tunnel)
NEXT_PUBLIC_BASE_URL=https://your-tunnel-url.loca.lt