{
  "name": "saas-ecommerce",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "db:generate": "cd packages/db && drizzle-kit generate",
    "db:migrate": "cd packages/db && drizzle-kit migrate",
    "db:seed": "tsx packages/db/seed.ts",
    "setup": "pnpm install && docker-compose up -d && pnpm db:generate && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  }
  
}
