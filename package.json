{
  "name": "saas-ecommerce",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "db:generate": "cd packages/db && drizzle-kit generate",
    "db:migrate": "cd packages/db && drizzle-kit up",
    "db:seed": "tsx packages/db/seed.ts",
    "setup": "pnpm install && docker-compose up -d && pnpm db:generate && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.45.0",
    "ioredis": "^5.10.1",
    "mercadopago": "^2.12.0",
    "minio": "^8.0.7",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  }
}
